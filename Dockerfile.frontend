# Build stage
FROM node:22-alpine AS builder
WORKDIR /app
COPY frontend/package*.json ./
RUN npm install --legacy-peer-deps && npm run build

# Production stage - use minimal Node image
FROM node:22-alpine
WORKDIR /app
COPY frontend/server.js ./
COPY --from=builder /app/dist ./dist
EXPOSE 3000
CMD ["node", "server.js"]
