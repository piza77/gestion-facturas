{
  "$schema": "https://railway.com/railway.schema.json",
  "services": {
    "backend": {
      "build": {
        "builder": "RAILPACK",
        "buildCommand": "npm run setup"
      },
      "deploy": {
        "startCommand": "node ./backend/server.js"
      }
    },
    "frontend": {
      "build": {
        "builder": "dockerfile",
        "dockerfilePath": "Dockerfile.prod"
      },
      "deploy": {
        "startCommand": ""
      }
    }
  }
}

